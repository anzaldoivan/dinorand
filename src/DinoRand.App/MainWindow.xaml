<Window x:Class="DinoRand.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DinoRand.App"
        mc:Ignorable="d"
        Title="DinoRand: Dino Crisis 1 Randomizer"
        Width="520"
        Height="640"
        MinWidth="460"
        Loaded="Window_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="8">
        <StackPanel>

            <!-- Header -->
            <Grid Margin="4,4,4,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="DinoRand"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="lblVersion"
                               Text="v0.2.0"
                               Margin="8,0,0,0"
                               VerticalAlignment="Bottom"
                               Foreground="Gray"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/anzaldoivan/dinorand"
                               RequestNavigate="Hyperlink_RequestNavigate">GitHub</Hyperlink>
                </TextBlock>
            </Grid>

            <!-- Game Location -->
            <GroupBox Header="Game Location"
                      Margin="4">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="txtGamePath"
                             Grid.Row="0"
                             Grid.Column="0"
                             Margin="0,0,4,0"
                             VerticalContentAlignment="Center"
                             LostFocus="txtGamePath_LostFocus"/>
                    <Button x:Name="btnBrowseGame"
                            Grid.Row="0"
                            Grid.Column="1"
                            Content="Browse..."
                            Padding="10,2"
                            Click="btnBrowseGame_Click"/>
                    <TextBlock x:Name="txtGameValidation"
                               Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </Grid>
            </GroupBox>

            <!-- Seed -->
            <GroupBox Header="Seed"
                      Margin="4">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <local:SeedQR x:Name="seedQr"
                                  Grid.Column="0"
                                  Width="96"
                                  Height="96"
                                  VerticalAlignment="Top"
                                  Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBox x:Name="txtSeed"
                                 FontFamily="Courier New"
                                 FontSize="20"
                                 VerticalContentAlignment="Center"
                                 TextChanged="txtSeed_TextChanged"/>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,6,0,0">
                            <Button x:Name="btnPaste"
                                    Content="Paste"
                                    Padding="10,2"
                                    Margin="0,0,4,0"
                                    Click="btnPaste_Click"/>
                            <Button x:Name="btnCopy"
                                    Content="Copy"
                                    Padding="10,2"
                                    Margin="0,0,4,0"
                                    Click="btnCopy_Click"/>
                            <Button x:Name="btnRandomize"
                                    Content="Randomize Seed"
                                    Padding="10,2"
                                    Click="btnRandomize_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Options -->
            <GroupBox Header="Options"
                      Margin="4">
                <StackPanel Margin="4">
                    <CheckBox x:Name="chkItems"
                              Content="Randomize Items"
                              Margin="0,2"
                              Checked="Option_Changed"
                              Unchecked="Option_Changed"/>
                    <CheckBox x:Name="chkEnemies"
                              Content="Randomize Enemies (EXPERIMENTAL/Crash Risk)"
                              Margin="0,2"
                              ToolTip="Permute enemy types within each room (same-category swaps; scripted bosses left untouched)."
                              Checked="Option_Changed"
                              Unchecked="Option_Changed"/>
                    <CheckBox x:Name="chkDoors"
                              Content="Randomize Doors (EXPERIMENTAL/Soft-Lock Risk)"
                              Margin="0,2"
                              ToolTip="Shuffle where doors lead (reciprocal, kept provably beatable; scripted/cutscene doors left vanilla)."
                              Checked="Option_Changed"
                              Unchecked="Option_Changed"/>
                    <CheckBox x:Name="chkShuffleKeys"
                              Content="Shuffle Key Items (EXPERIMENTAL/Soft-Lock Risk)"
                              Margin="0,2"
                              ToolTip="Relocate the door-gating key items (Entrance / BG Area / C.O. Area keys, Key Card Lv A) to new spots, kept provably beatable."
                              Checked="Option_Changed"
                              Unchecked="Option_Changed"/>
                    <CheckBox x:Name="chkInventory"
                              Content="Randomize starting inventory (EXPERIMENTAL)"
                              Margin="0,2"
                              ToolTip="EXPERIMENTAL — patches DINO.exe so a new game starts with a randomized supply kit (the Handgun and its ammo are always granted, so it stays beatable). Seen on the next new game after relaunch."
                              Checked="Option_Changed"
                              Unchecked="Option_Changed"/>
                    <!-- Randomize Cutscene Voices. BioRand-style group box: the header checkbox is the master
                         enable; its children disable as a unit. Each of Regina/Rick/Gail/Kirk gets a donor
                         dropdown (Random or a specific character). Installed with the seed, reversed by
                         Restore (docs/decisions/dc1/voice/VOICE-UI-PLAN.md §10). -->
                    <local:CheckGroupBox x:Name="grpVoices"
                                         Header="Randomize Cutscene Voices"
                                         Margin="0,8,0,2"
                                         OnCheckedChanged="grpVoices_CheckedChanged">
                        <StackPanel Margin="6,4,4,4">
                            <TextBlock Text="Voice Packs folder (e.g. biorand\datapacks)"
                                       Margin="0,0,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtVoicePacksRoot"
                                         Grid.Column="0"
                                         Margin="0,0,4,0"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Folder holding the BioRand-layout donor datapacks (each subfolder or .zip is a pack). Discovered characters populate the dropdowns below."
                                         LostFocus="txtVoicePacksRoot_LostFocus"/>
                                <Button x:Name="btnBrowseVoicePacks"
                                        Grid.Column="1"
                                        Content="Browse..."
                                        Padding="10,2"
                                        Click="btnBrowseVoicePacks_Click"/>
                            </Grid>
                            <TextBlock x:Name="txtVoicePacksValidation"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>

                            <CheckBox x:Name="chkCrossGameVoices"
                                      Content="Allow voices from other games (RE1/2/3, …)"
                                      Margin="0,8,0,2"
                                      ToolTip="DC1's own cast has only Regina, so with this OFF the dropdowns only offer Regina. Turn it ON to add the cross-game roster (Claire, Leon, …)."
                                      Checked="chkCrossGameVoices_Changed"
                                      Unchecked="chkCrossGameVoices_Changed"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Regina speaks as"
                                           VerticalAlignment="Center"
                                           Margin="0,2,8,2"/>
                                <ComboBox x:Name="cboDonorRegina"
                                          Grid.Row="0"
                                          Grid.Column="1"
                                          Margin="0,2"
                                          SelectionChanged="cboVoiceDonor_SelectionChanged"/>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="Rick speaks as"
                                           VerticalAlignment="Center"
                                           Margin="0,2,8,2"/>
                                <ComboBox x:Name="cboDonorRick"
                                          Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="0,2"
                                          SelectionChanged="cboVoiceDonor_SelectionChanged"/>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Gail speaks as"
                                           VerticalAlignment="Center"
                                           Margin="0,2,8,2"/>
                                <ComboBox x:Name="cboDonorGail"
                                          Grid.Row="2"
                                          Grid.Column="1"
                                          Margin="0,2"
                                          SelectionChanged="cboVoiceDonor_SelectionChanged"/>

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Text="Kirk speaks as"
                                           VerticalAlignment="Center"
                                           Margin="0,2,8,2"/>
                                <ComboBox x:Name="cboDonorKirk"
                                          Grid.Row="3"
                                          Grid.Column="1"
                                          Margin="0,2"
                                          SelectionChanged="cboVoiceDonor_SelectionChanged"/>
                            </Grid>
                        </StackPanel>
                    </local:CheckGroupBox>
                    <local:RandoSlider x:Name="sliderDifficulty"
                                       Margin="0,8,0,0"
                                       Heading="Enemy Difficulty"
                                       LowText="Easy"
                                       HighText="Hard"
                                       Maximum="31"
                                       IsEnabled="{Binding IsChecked, ElementName=chkEnemies}"
                                       ValueChanged="sliderDifficulty_ValueChanged"/>

                    <!-- Item-pool mode + pickup distribution. The replace toggle gates the
                         distribution panel (ratios are meaningless for a pure shuffle). All of this
                         is shown only while Randomize Items is on (gated in code-behind). -->
                    <CheckBox x:Name="chkReplacePool"
                              Content="Replace item pool (random pickups)"
                              Margin="0,10,0,0"
                              ToolTip="Checked: every non-key pickup becomes a weighted-random item. Unchecked: keep the game's items but shuffle their locations."
                              Checked="Option_Changed"
                              Unchecked="Option_Changed"/>
                    <StackPanel x:Name="pnlItemRatios"
                                Margin="0,8,0,0">
                        <TextBlock Text="Item Pickup Distribution"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <local:PieChart x:Name="pieItemRatios"
                                            Grid.Column="0"
                                            Width="120"
                                            VerticalAlignment="Top"
                                            ToolTip="The Keys slice is illustrative (a fixed reserve) — key items are placed by logic, not by this ratio."/>
                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <local:RandoSlider x:Name="sliderAmmo"
                                                   Heading="Ammo"
                                                   LowText="None"
                                                   HighText="High"
                                                   Maximum="31"
                                                   ToolTip="Bias of non-key pickups toward ammunition."
                                                   ValueChanged="sliderItemRatio_ValueChanged"/>
                                <local:RandoSlider x:Name="sliderHealth"
                                                   Margin="0,6,0,0"
                                                   Heading="Health"
                                                   LowText="None"
                                                   HighText="High"
                                                   Maximum="31"
                                                   ToolTip="Bias of non-key pickups toward healing items."
                                                   ValueChanged="sliderItemRatio_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="lblRatioVanilla"
                                   Margin="16,2,0,0"
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   ToolTip="Equal Ammo and Health bias reproduces the game's own pickup split (no tilt). Move either slider to bias the mix."/>
                        <local:RandoSlider x:Name="sliderAmmoQuantity"
                                           Margin="0,6,0,0"
                                           Heading="Ammo average quantity"
                                           LowText="Less"
                                           HighText="More"
                                           CenterText="▲ Vanilla"
                                           ShowTicks="True"
                                           Maximum="14"
                                           ToolTip="Scales the size of ammunition stacks. The midpoint is the game's vanilla amount; drag left for smaller ammo stacks, right for larger ones."
                                           ValueChanged="sliderItemRatio_ValueChanged"/>
                        <local:RandoSlider x:Name="sliderWeaponUpgrade"
                                           Margin="0,6,0,0"
                                           Heading="Weapon upgrade part frequency"
                                           LowText="None"
                                           HighText="All"
                                           Maximum="15"
                                           ToolTip="How often a weapon's upgrade part is placed when that weapon is in the pool. 'All' places every upgrade part (vanilla); 'None' means upgrades never appear. Parts whose base weapon isn't in the seed are never placed regardless."
                                           ValueChanged="sliderItemRatio_ValueChanged"/>
                        <CheckBox x:Name="chkPreUpgradedWeapons"
                                  Content="Insert upgraded weapons"
                                  Margin="0,8,0,0"
                                  ToolTip="EXPERIMENTAL / UNVALIDATED: base weapons may be placed already-upgraded, using weapon variant ids the vanilla game never hands out as a pickup. Needs in-game confirmation before relying on it. Off by default."
                                  Checked="Option_Changed"
                                  Unchecked="Option_Changed"/>
                        <TextBlock Text="Weapons in pool"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,2"
                                   ToolTip="Unchecking a weapon family drops its pickups and upgrade parts from the pool — those spots become consumables instead. Your starting handgun (and its 9mm) is unaffected."/>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkWeaponHandgun"
                                      Content="Handgun"
                                      Margin="0,0,12,0"
                                      ToolTip="Include Handgun pickups/upgrades (Glock 34/35 + sights/slides). You always keep the starting handgun regardless."
                                      Checked="Option_Changed"
                                      Unchecked="Option_Changed"/>
                            <CheckBox x:Name="chkWeaponShotgun"
                                      Content="Shotgun"
                                      Margin="0,0,12,0"
                                      ToolTip="Include Shotgun pickups/upgrades (PA3 / SPAS12 + parts/stock)."
                                      Checked="Option_Changed"
                                      Unchecked="Option_Changed"/>
                            <CheckBox x:Name="chkWeaponGrenade"
                                      Content="Grenade Gun"
                                      ToolTip="Include Grenade Gun pickups/upgrades (40mmHK + Regina Custom part)."
                                      Checked="Option_Changed"
                                      Unchecked="Option_Changed"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Generate. Generated room files go to a fixed per-user working folder (shown in the status
                 line on success); they're only consumed by "Install to Game" below, so there's no folder to
                 pick — the game has no mod-load path of its own. -->
            <Grid Margin="4,8,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblProgress"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
                <Button x:Name="btnGenerate"
                        Grid.Column="1"
                        Content="Generate"
                        Padding="20,6"
                        FontWeight="Bold"
                        Background="#FF4CAF50"
                        Foreground="White"
                        Click="btnGenerate_Click"/>
            </Grid>

            <!-- Busy indicator for the off-thread generation/install step. Indeterminate because the
                 pipeline doesn't report granular progress; collapsed while idle. -->
            <ProgressBar x:Name="genProgress"
                         Height="6"
                         Margin="4,0,4,0"
                         IsIndeterminate="True"
                         Visibility="Collapsed"/>

            <!-- Install to game -->
            <GroupBox Header="Install to Game"
                      Margin="4,8,4,4">
                <StackPanel Margin="4">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="Gray"
                               Margin="0,0,0,6"
                               Text="Overlays the generated rooms onto the game's Data folder. Your originals are backed up first and can be restored at any time."/>
                    <CheckBox x:Name="chkShuffleBgm"
                              Content="Shuffle music (BGM)"
                              Margin="0,0,0,6"
                              ToolTip="Also patch DINO.exe so every track plays a different cue (within its stream/loop class), seeded from the same seed. Reversed by Restore. CLOSE the game first — it edits the executable, and the change is heard after the next launch."/>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,6">
                        <CheckBox x:Name="chkRandomizeBoxes"
                                  Content="Randomize emergency boxes"
                                  VerticalAlignment="Center"
                                  ToolTip="EXPERIMENTAL: also patch DINO.exe to randomize emergency-box contents (seeded from the same seed). Plug costs and box locations are unchanged. Reversed by Restore. CLOSE the game first — the change is seen after the next launch."/>
                        <ComboBox x:Name="cboBoxMode"
                                  Width="150"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  SelectedIndex="0"
                                  IsEnabled="{Binding IsChecked, ElementName=chkRandomizeBoxes}"
                                  ToolTip="Shuffle = move each box's whole loadout to another box. Reroll from box pool = redraw each box's items from that difficulty's own box loot (distinct from map drops).">
                            <ComboBoxItem Content="Shuffle"/>
                            <ComboBoxItem Content="Reroll from box pool"/>
                        </ComboBox>
                    </StackPanel>
                    <Expander Header="Starting inventory (EXPERIMENTAL)"
                              Margin="0,0,0,6">
                        <StackPanel Margin="0,4,0,0">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="Gray"
                                       Margin="0,0,0,6"
                                       Text="Patches DINO.exe for the new game. 'Randomize starting inventory' (Options) rolls a random supply kit; here you can pin the starting weapon and/or set explicit supply slots. CLOSE the game first — seen on the next NEW GAME, reversed by Restore."/>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <TextBlock Text="Starting weapon:"
                                           VerticalAlignment="Center"
                                           Width="110"/>
                                <ComboBox x:Name="cboStartWeapon"
                                          Width="200"
                                          SelectedIndex="0"
                                          ToolTip="Vanilla keeps the game's start (Handgun). None = start weaponless; the removed Handgun is then placed in the early world (needs Randomize Items on). Or pick a weapon to start with instead."/>
                            </StackPanel>
                            <StackPanel x:Name="pnlCustomSupply">
                                <TextBlock x:Name="lblCustomSupply"
                                           Text="Custom supply slots (optional — overrides the Randomize kit):"
                                           Foreground="Gray"
                                           Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,3">
                                    <ComboBox x:Name="cboItem0"
                                              Width="200"
                                              SelectedIndex="0"/>
                                    <TextBlock Text="×"
                                               VerticalAlignment="Center"
                                               Margin="6,0"/>
                                    <TextBox x:Name="txtCount0"
                                             Width="50"
                                             Text="1"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,3">
                                    <ComboBox x:Name="cboItem1"
                                              Width="200"
                                              SelectedIndex="0"/>
                                    <TextBlock Text="×"
                                               VerticalAlignment="Center"
                                               Margin="6,0"/>
                                    <TextBox x:Name="txtCount1"
                                             Width="50"
                                             Text="1"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,3">
                                    <ComboBox x:Name="cboItem2"
                                              Width="200"
                                              SelectedIndex="0"/>
                                    <TextBlock Text="×"
                                               VerticalAlignment="Center"
                                               Margin="6,0"/>
                                    <TextBox x:Name="txtCount2"
                                             Width="50"
                                             Text="1"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Expander>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="lblInstallStatus"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <Button x:Name="btnPlay"
                                Grid.Column="1"
                                Content="▶ Play"
                                Padding="12,6"
                                Margin="0,0,6,0"
                                ToolTip="Launch the selected DINO.exe. Whatever is currently in the game's Data folder is what loads — install first to play the randomized rooms."
                                Click="btnPlay_Click"/>
                        <Button x:Name="btnRestore"
                                Grid.Column="2"
                                Content="Restore Originals"
                                Padding="12,6"
                                Margin="0,0,6,0"
                                Click="btnRestore_Click"/>
                        <Button x:Name="btnInstall"
                                Grid.Column="3"
                                Content="Install to Game"
                                Padding="14,6"
                                FontWeight="Bold"
                                Click="btnInstall_Click"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</Window>
